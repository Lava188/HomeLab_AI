PORT=5000
# Preferred retriever runtime selector. Keep v1_2 as the safe default.
HOMELAB_RETRIEVER_VERSION=v1_2
# Backward-compatible legacy selector. Do not remove while existing runtime/docs use it.
HOMELAB_HEALTH_RAG_VERSION=v1_2
# Runtime fallback if the configured retriever version cannot be loaded.
HOMELAB_RETRIEVER_FALLBACK_VERSION=v1_2
# Optional direct artifact folder override under ai_lab/artifacts, for controlled local testing only.
# HEALTH_RAG_ARTIFACT_DIR=retriever_v1_3
