{
  "schema_version": "slot_schema_v1",
  "status": "draft",
  "purpose": "Minimal slot schema for asking follow-up questions before package recommendation.",
  "slot_state_convention": {
    "not_asked": "A slot that is absent from the collected slot state has not been asked yet.",
    "unknown_value": "If a slot supports unknown, the explicit stored value must be the string 'unknown'.",
    "boolean_like_encoding": "Boolean-like slots that support unknown may store true, false, or 'unknown'.",
    "recommendation_goal_note": "For recommendation_goal, the explicit value 'unsure' means the user cannot specify a package direction yet. It is not the same as not_asked."
  },
  "notes": [
    "This schema supports planning for recommendation-time clarification only.",
    "It does not implement a live multi-turn controller."
  ],
  "slots": [
    {
      "slot_id": "recommendation_goal",
      "display_name": "Recommendation Goal",
      "question_vi": "Ban dang muon kiem tra theo huong nao?",
      "question_en": "What kind of test package are you looking for?",
      "value_type": "enum",
      "allowed_values": [
        "basic_blood_package",
        "anemia_infection_screening",
        "glucose_screening",
        "lipid_screening",
        "kidney_function_screening",
        "liver_function_screening",
        "infectious_screening",
        "unsure"
      ],
      "required_for": [
        "general_basic_screening_flow",
        "anemia_infection_flow",
        "glucose_flow",
        "lipid_flow",
        "kidney_function_flow",
        "blocked_package_flow"
      ],
      "optional_for": [],
      "red_flag_relevance": "none",
      "affects_eligibility": true,
      "affects_exclusion": false,
      "affects_prep": false,
      "affects_escalation": false,
      "collection_priority": 1,
      "not_asked_behavior": "slot_absent",
      "notes": "Primary intent-routing slot. The explicit value 'unsure' means the user cannot choose a package direction yet."
    },
